{
  "name": "frontend",
  "version": "1.0.0",
  "type": "module",
  "description": "This is a code bundle for Dark Mode Admin Dashboard. The original project is available at https://www.figma.com/design/jLhWitNaDjM4DN8h5DCExU/Dark-Mode-Admin-Dashboard.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dev:desktop": "concurrently -k \"vite --host 127.0.0.1 --port 3000 --strictPort --open false\" \"wait-on tcp:127.0.0.1:3000 && cross-env ELECTRON_START_URL=http://127.0.0.1:3000 electron .\"",
    "start:desktop": "cross-env ELECTRON_START_URL=http://127.0.0.1:3000 electron .",
    "build:desktop": "npm run build && electron-builder",
    "pack:desktop": "npm run build && electron-builder --dir"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react-swc": "^4.2.3",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.4",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-pwa": "^1.2.0",
    "wait-on": "^9.0.1"
  },
  "build": {
    "appId": "com.engagex.desktop",
    "productName": "EngageX Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "build/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
